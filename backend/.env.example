# MongoDB bağlantı stringi (Atlas veya lokal)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/firma-yonetim?retryWrites=true&w=majority

# JWT ayarları
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d

# Server ayarları
PORT=5001
NODE_ENV=development

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:3000

# Cloudinary (dosya yükleme — opsiyonel)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Gemini AI (akıllı import fallback — opsiyonel)
# GEMINI_API_KEY=your-gemini-key
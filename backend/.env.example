# MongoDB bağlantı stringi (Atlas veya lokal)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/firma-yonetim?retryWrites=true&w=majority

# JWT ayarları
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d

# Server ayarları
PORT=5001
NODE_ENV=development

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:3000

# Cloudinary (dosya yükleme — opsiyonel)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Gemini AI (akıllı import fallback — opsiyonel)
# GEMINI_API_KEY=your-gemini-key

# ─────────────────────────────────────────────────────────────
# 🛠️ TEŞVİK MAKİNE TEÇHİZAT YÖNETİMİ MODÜLÜ
# ─────────────────────────────────────────────────────────────

# 📮 SMTP (kurumsal mail gönderimi) — boşsa mailler taslak kalır, gönderilmez
# Gönderen adresi değiştirmek için SMTP_USER + SMTP_FROM_EMAIL'i güncelleyin (ör. bilgi@gmplanlama.com)
# (Gmail kullanıyorsanız o hesabın kendi App Password'ü gerekir)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=GM Planlama Yatırım Danışmanlık
SMTP_FROM_EMAIL=
SMTP_SECURE=false            # 465 portu için true, 587 için false

# ⚙️ Süreç ayarları
AUTO_SEND_ENABLED=false      # true → otomasyon kodu girilince mail otomatik gönderilir
REMINDER_DAYS=7              # kaç gün cevap gelmezse hatırlatma
MAX_UPLOAD_MB=20             # evrak yükleme maks boyut (dosya başına)
MAX_UPLOAD_FILES=10          # tek seferde yüklenebilecek maks dosya (XML+PDF birlikte)
# UPLOAD_TOKEN_DAYS=         # public link süresi (gün). Boş → süresiz
# UPLOAD_PUBLIC_BASE_URL=    # müşteriye gösterilecek şık link tabanı (ör. https://gmplanlama.com). Boş → FRONTEND_URL
# UPLOAD_NOTIFY_EMAIL=       # firma evrak yükleyince bilgilendirme mailinin gideceği adres. Boş → SMTP_FROM_EMAIL / SMTP_USER
# MAIL_SIGNATURE=            # mail imzası override (satır için \n kullanın). Boş → varsayılan imza
# TESVIK_UPLOAD_DIR=         # evrak kök dizini override. Boş → backend/uploads/tesvik-evrak

# 🗂️ Depolama sağlayıcı (varsayılan: local disk)
DRIVE_ENABLED=false          # Google Drive entegrasyonu (opsiyonel — şimdilik local fallback)
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# S3_ENABLED=false           # S3-uyumlu storage (opsiyonel — şimdilik local fallback)